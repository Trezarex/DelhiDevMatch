# DelhiDevMatch Environment Variables
# Copy this file to .env.local and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Enable starfield background (true/false)
NEXT_PUBLIC_STARFIELD_ENABLED=true

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# Admin panel password (used for Bearer token auth)
ADMIN_PASSWORD=admin123

# Adzuna API (optional — needed for job refresh)
# Get free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
