# DelhiDevMatch Environment Variables
# Copy this file to .env and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Enable starfield background (true/false)
NEXT_PUBLIC_STARFIELD_ENABLED=true

# Local SQLite (used for local dev when Turso vars are not set)
DATABASE_URL="file:./dev.db"

# Turso Cloud Database (used in production / Vercel)
# Get free account at https://turso.tech
# Run: turso db create delhidevmatch
# Run: turso db show delhidevmatch --url
# Run: turso db tokens create delhidevmatch
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Admin panel password (used for Bearer token auth)
ADMIN_PASSWORD=admin123

# Adzuna API (optional — needed for job refresh)
# Get free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
